# OpenVault environment configuration.
# Copy this file to .env.local and fill in your values (real secrets live in
# .env.local, which is gitignored — never put real keys in THIS example file).
# Leave NEXT_PUBLIC_MOCK=1 to run with NO credentials in deterministic mock mode.
# Set it to 0 (and provide the keys below) to run against Story Aeneid + CDR.

NEXT_PUBLIC_RPC_URL=https://aeneid.storyrpc.io
NEXT_PUBLIC_STORY_API_URL=http://172.192.41.96:1317
NEXT_PUBLIC_PRIVY_APP_ID=
PINATA_JWT=
WALLET_PRIVATE_KEY=

# MOCK=1 runs the app without any credentials (browser-verifiable demo mode).
NEXT_PUBLIC_MOCK=1
