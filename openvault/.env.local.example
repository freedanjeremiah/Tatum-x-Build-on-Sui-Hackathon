# OpenVault environment configuration.
# Copy this file to .env.local and fill in your values.
# Leave NEXT_PUBLIC_MOCK=1 (default) to run the app with NO credentials in
# deterministic mock mode. Set it to 0 (and provide the keys below) to run
# against the real Story Aeneid testnet + CDR network.

NEXT_PUBLIC_RPC_URL=https://aeneid.storyrpc.io
NEXT_PUBLIC_STORY_API_URL=http://172.192.41.96:1317
NEXT_PUBLIC_PRIVY_APP_ID=
PINATA_JWT=
WALLET_PRIVATE_KEY=

# MOCK=1 runs the app without any credentials (browser-verifiable demo mode).
NEXT_PUBLIC_MOCK=1
