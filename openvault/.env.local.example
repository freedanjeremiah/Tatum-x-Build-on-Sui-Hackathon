# OpenVault — runtime env (real-only). Copy to .env.local before `pnpm dev`.
# Only these three are read by the code. Everything else is hardcoded in
# lib/constants.ts (RPC, contract addresses, CDR endpoint).

# Privy app id for wallet auth. Without this, the Connect button cannot
# initialise. Read by: lib/env.ts.
NEXT_PUBLIC_PRIVY_APP_ID=

# Server-side secret. Used by scripts, the indexer, and the compute worker to
# sign writes (register IP, mint license, register derivative). NOT shipped
# to the browser. Read by: lib/clients.ts, worker/compute-worker.ts.
WALLET_PRIVATE_KEY=

# Pinata JWT for IPFS pinning (gated/private/compute artifacts pin ciphertext;
# public artifacts pin clear bytes). Server-only. Read by: lib/storage.ts.
PINATA_JWT=

# --- Confidential-compute TEE attestation (optional) -----------------------
# Verify CDR validator SGX enclaves during compute decryption. Read by
# lib/attestation.ts. All optional:
#   CDR_ATTEST=1             -> report-only: verify validator attestation, exclude
#                              untrusted, no required measurement.
#   CDR_ATTEST_MRENCLAVE=0x… -> require this MRENCLAVE (enforced).
#   CDR_ATTEST_MRSIGNER=0x…  -> require this MRSIGNER.
#   CDR_ATTEST_MIN_SVN=N     -> require minimum security version.
# Unset -> attestation off (testnet default).
#CDR_ATTEST=1
#CDR_ATTEST_MRENCLAVE=
#CDR_ATTEST_MRSIGNER=
#CDR_ATTEST_MIN_SVN=
# Declare the worker runs in an attested enclave (only if it truly does); else
# honest "plain-server" disclosure. Read by lib/attestation.ts.
#WORKER_ISOLATION_MODE=enclave
