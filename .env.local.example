# OpenVault — runtime env (real-only). Copy to .env.local before `pnpm dev`.
# Only these three are read by the code. Everything else is hardcoded in
# lib/constants.ts (RPC, contract addresses, CDR endpoint).

# Privy app id for wallet auth. Without this, the Connect button cannot
# initialise. Read by: lib/env.ts.
NEXT_PUBLIC_PRIVY_APP_ID=

# Server-side secret. Used by scripts, the indexer, and the compute worker to
# sign writes (register IP, mint license, register derivative). NOT shipped
# to the browser. Read by: lib/clients.ts, worker/compute-worker.ts.
WALLET_PRIVATE_KEY=

# Pinata JWT for IPFS pinning (gated/private/compute artifacts pin ciphertext;
# public artifacts pin clear bytes). Server-only. Read by: lib/storage.ts.
PINATA_JWT=

# --- Confidential-compute TEE attestation (optional) -----------------------
# Verify CDR validator SGX enclaves during compute decryption. Read by
# lib/attestation.ts. All optional:
#   CDR_ATTEST=1             -> report-only: verify validator attestation, exclude
#                              untrusted, no required measurement.
#   CDR_ATTEST_MRENCLAVE=0x… -> require this MRENCLAVE (enforced).
#   CDR_ATTEST_MRSIGNER=0x…  -> require this MRSIGNER.
#   CDR_ATTEST_MIN_SVN=N     -> require minimum security version.
# Unset -> attestation off (testnet default).
#CDR_ATTEST=1
#CDR_ATTEST_MRENCLAVE=
#CDR_ATTEST_MRSIGNER=
#CDR_ATTEST_MIN_SVN=
# Declare the worker isolation mode. Read by lib/attestation.ts.
#   enclave      -> real attested SGX/TDX (production)
#   enclave-sim  -> TEE-SIM v1: deterministic, structurally-valid simulated SGX
#                   quote generated by lib/tee-sim and verified by the worker.
#                   HONESTLY disclosed as not hardware-attested. Dev/CI only.
#   (unset)      -> plain server (operator-trusted, demo). Default.
#WORKER_ISOLATION_MODE=enclave-sim
# Optional per-deployment HMAC secret for sim quote signatures. If unset, a
# deterministic default seed is used (the sim is dev-only regardless).
#WORKER_SIM_KEY=
# Optional expected sim measurements (for sim verification — same shape as the
# CDR_ATTEST_* envs, just for the sim worker). Defaults: not enforced.
#WORKER_SIM_EXPECT_MRENCLAVE=
#WORKER_SIM_EXPECT_MRSIGNER=
#WORKER_SIM_MIN_SVN=

# --- Network / contract address overrides (optional) -----------------------
# Override Aeneid testnet defaults to point at a different network or your own
# deployed contracts. Read by lib/constants.ts. NEXT_PUBLIC_OV_* variants are
# visible in client bundles; OV_* variants are server-only.
#NEXT_PUBLIC_OV_RPC_URL=
#NEXT_PUBLIC_OV_CDR_API_URL=
#NEXT_PUBLIC_OV_EXPLORER_IPA=
#NEXT_PUBLIC_OV_STORYSCAN_TX=
#OV_OWNER_WRITE_CONDITION=
#OV_LICENSE_READ_CONDITION=
#OV_LICENSE_TOKEN=
#OV_ROYALTY_MODULE=
#OV_ROYALTY_POLICY_LAP=
#OV_EVEN_SPLIT_GROUP_POOL=
#OV_PUBLIC_SPG_COLLECTION=
#OV_IP_ASSET_REGISTRY=
#OV_ANY_OF_READ_CONDITION=
#OV_GROUP_LICENSE_READ_CONDITION=
#OV_COMPUTE_WORKER_READ_CONDITION=
#OV_COMPUTE_WORKER_OPERATOR=
