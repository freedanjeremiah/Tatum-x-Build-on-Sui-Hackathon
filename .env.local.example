# Reef — runtime env template for Sui / Walrus / Seal / Tatum.
# Copy to .env.local and fill in values. .env.local is gitignored.

# ---------------------------------------------------------------------------
# Privy — wallet auth (browser + server)
# ---------------------------------------------------------------------------

# Privy application id. Required for the Connect Wallet button.
# Read by: lib/env.ts, used in app/providers.tsx.
NEXT_PUBLIC_PRIVY_APP_ID=

# Privy application secret. Server-only (API routes, scripts).
PRIVY_APP_SECRET=

# ---------------------------------------------------------------------------
# Tatum — Sui RPC gateway
# ---------------------------------------------------------------------------

# Tatum API key. Attached as a header to all Sui JSON-RPC calls.
# Server-only. Read by: lib/env.ts, lib/clients.ts.
TATUM_API_KEY=

# ---------------------------------------------------------------------------
# Sui network
# ---------------------------------------------------------------------------

# Network identifier: testnet | mainnet | devnet (default: testnet).
# Read by: lib/constants.ts.
SUI_NETWORK=testnet

# Tatum Sui JSON-RPC gateway. Read by: lib/constants.ts (primary RPC).
TATUM_SUI_JSONRPC=https://sui-testnet.gateway.tatum.io

# Public Sui fullnode (fallback). Read by: lib/constants.ts.
SUI_FULLNODE_URL=https://fullnode.testnet.sui.io

# Server signer: Ed25519 keypair in Sui bech32 format (suiprivkey1...) or
# base64 seed. Used by scripts, indexer, and compute worker to sign txs.
# NOT shipped to the browser. Read by: lib/clients.ts, worker/compute-worker.ts.
MASTER_SUI_PRIVKEY=

# Corresponding Sui address (0x…). Read by: lib/clients.ts.
MASTER_SUI_ADDRESS=

# ---------------------------------------------------------------------------
# Reef Move package
# ---------------------------------------------------------------------------

# Object id of the published `reef` Move package on the target network.
# Required for on-chain registry and Seal seal_approve calls.
# Read by: lib/constants.ts.
REEF_PACKAGE_ID=

# ---------------------------------------------------------------------------
# Walrus storage
# ---------------------------------------------------------------------------

# Walrus publisher endpoint. Read by: lib/constants.ts.
WALRUS_PUBLISHER=https://publisher.walrus-testnet.walrus.space

# Walrus aggregator endpoint. Read by: lib/constants.ts.
WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space

# Number of epochs to store each blob (default: 5). Read by: lib/constants.ts.
STORAGE_EPOCHS=5

# ---------------------------------------------------------------------------
# Seal — threshold encryption / access policy
# ---------------------------------------------------------------------------

# Comma-separated Seal key-server object ids (on-chain ids, testnet).
# Required for encrypt/decrypt operations. Read by: lib/constants.ts.
SEAL_KEY_SERVER_IDS=

# Minimum key-server responses required to decrypt (k-of-n, default: 2).
# Read by: lib/constants.ts.
SEAL_THRESHOLD=2

# ---------------------------------------------------------------------------
# Inference backend (optional)
# ---------------------------------------------------------------------------

# OpenAI-compatible base URL, e.g. http://3.111.31.183:8443/v1
# Empty = inference disabled (API route returns 503). Server-only.
# Read by: lib/env.ts.
INFERENCE_BASE_URL=
INFERENCE_TOKEN=
INFERENCE_MODEL=llama3.1:8b

# ---------------------------------------------------------------------------
# Worker isolation (optional)
# ---------------------------------------------------------------------------

# Declare the worker isolation mode. Read by lib/attestation.ts.
#   enclave      -> real attested SGX/TDX (production)
#   enclave-sim  -> TEE-SIM v1: deterministic, structurally-valid simulated SGX
#                   quote generated by lib/tee-sim and verified by the worker.
#                   HONESTLY disclosed as not hardware-attested. Dev/CI only.
#   (unset)      -> plain server (operator-trusted, demo). Default.
#WORKER_ISOLATION_MODE=enclave-sim

# Optional per-deployment HMAC secret for sim quote signatures.
#WORKER_SIM_KEY=

# ---------------------------------------------------------------------------
# Network / endpoint overrides (optional)
# ---------------------------------------------------------------------------

# Override testnet defaults without code edits. NEXT_PUBLIC_OV_* vars are
# visible in the browser bundle; OV_* vars are server-only.
# Read by: lib/constants.ts.
#NEXT_PUBLIC_OV_SUI_NETWORK=
#NEXT_PUBLIC_OV_TATUM_SUI_JSONRPC=
#NEXT_PUBLIC_OV_SUI_FULLNODE_URL=
#NEXT_PUBLIC_OV_WALRUS_PUBLISHER=
#NEXT_PUBLIC_OV_WALRUS_AGGREGATOR=
#NEXT_PUBLIC_OV_STORAGE_EPOCHS=
#NEXT_PUBLIC_OV_SEAL_THRESHOLD=
#NEXT_PUBLIC_OV_REEF_PACKAGE_ID=
#NEXT_PUBLIC_OV_SUI_EXPLORER_TX=
#NEXT_PUBLIC_OV_SUI_EXPLORER_OBJECT=
#OV_SEAL_KEY_SERVER_IDS=
